---
import Layout from "../../layouts/Layout.astro";
import { products } from "../../data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const pageTitle = `${product.name} | Catálogo Cardan Oeste`;
const pageDescription = `${product.description} Confira especificações técnicas e solicite detalhes da ${product.name} com a equipe da Cardan Oeste.`;
const whatsappText = encodeURIComponent(
  `Olá, tenho interesse em ${product.name}. Pode me enviar especificações completas, disponibilidade e valor?`
);

const productLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: product.description,
  image: product.gallery?.length ? product.gallery : [product.image],
  category: "Componentes e Eixos Cardan",
  brand: {
    "@type": "Brand",
    name: "Cardan Oeste",
  },
};
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="bg-gradient-to-b from-white via-[#fdeeea] to-white py-16">
    <section class="mx-auto grid max-w-6xl gap-10 px-6 lg:grid-cols-[1.1fr,0.9fr]">
      <article class="overflow-hidden rounded-3xl border border-[#f3c0b3] bg-white shadow-sm">
        <button
          type="button"
          class="js-open-full-image block w-full text-left"
          data-src={product.image}
          data-alt={product.name}
          aria-label={`Abrir imagem completa de ${product.name}`}
        >
          <img
            src={product.image}
            alt={product.name}
            width={product.width}
            height={product.height}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="h-[420px] w-full object-cover sm:h-[520px]"
          />
        </button>
      </article>

      <aside class="space-y-6 rounded-3xl border border-[#f3c0b3] bg-white p-8 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[#de3f21]">Detalhes do Produto</p>
        <h1 class="text-3xl font-bold leading-tight text-slate-900">{product.name}</h1>
        <p class="text-sm leading-relaxed text-slate-600">{product.description}</p>

        <div class="space-y-3 rounded-2xl border border-[#f3c0b3] bg-[#fff7f5] p-4 text-sm text-slate-700">
          <p><strong>Material:</strong> {product.specs.material}</p>
          <p><strong>Aplicação:</strong> {product.specs.aplicacao}</p>
          <p><strong>Diferencial:</strong> {product.specs.diferencial}</p>
          <p><strong>Observação:</strong> {product.specs.observacao}</p>
        </div>

        <div class="flex items-center gap-3">
          <a
            href="/produtos"
            class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#de3f21] text-[#de3f21] transition hover:bg-[#de3f21] hover:text-white"
            aria-label="Voltar para catálogo"
            title="Voltar ao catálogo"
          >
            <i class="bi bi-grid"></i>
          </a>
          <a
            href={`https://api.whatsapp.com/send?phone=5521964210745&text=${whatsappText}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-green-600 text-green-600 transition hover:bg-green-600 hover:text-white"
            aria-label={`Pedir detalhes no WhatsApp sobre ${product.name}`}
            title="Pedir detalhes no WhatsApp"
          >
            <i class="bi bi-whatsapp"></i>
          </a>
        </div>
      </aside>
    </section>

    {
      product.gallery && product.gallery.length > 1 && (
        <section class="mx-auto mt-10 max-w-6xl px-6">
          <h2 class="text-sm font-semibold uppercase tracking-[0.3em] text-[#de3f21]">Mais Fotos</h2>
          <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {product.gallery.map((image, index) => (
              <button
                type="button"
                class="js-open-full-image block text-left"
                data-src={image}
                data-alt={`${product.name} - imagem ${index + 1}`}
                aria-label={`Abrir imagem ${index + 1} em tamanho completo`}
              >
                <img
                  src={image}
                  alt={`${product.name} - imagem ${index + 1}`}
                  width="1200"
                  height="800"
                  loading="lazy"
                  decoding="async"
                  class="h-56 w-full rounded-2xl border border-[#f3c0b3] object-cover shadow-sm"
                />
              </button>
            ))}
          </div>
        </section>
      )
    }

    <dialog
      id="product-image-lightbox"
      class="m-auto w-[92vw] max-w-6xl rounded-2xl border border-[#f3c0b3] bg-white p-0 backdrop:bg-black/80"
    >
      <div class="relative">
        <button
          type="button"
          id="lightbox-close"
          class="absolute right-3 top-3 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full bg-black/70 text-white transition hover:bg-black"
          aria-label="Fechar imagem"
        >
          <i class="bi bi-x-lg"></i>
        </button>
        <img id="lightbox-image" src="" alt="" class="max-h-[88vh] w-full rounded-2xl object-contain bg-black" />
      </div>
    </dialog>
  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const lightbox = document.getElementById("product-image-lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const closeButton = document.getElementById("lightbox-close");
      const triggers = document.querySelectorAll(".js-open-full-image");

      if (!(lightbox instanceof HTMLDialogElement) || !(lightboxImage instanceof HTMLImageElement)) {
        return;
      }

      triggers.forEach((trigger) => {
        if (!(trigger instanceof HTMLElement)) {
          return;
        }

        trigger.addEventListener("click", () => {
          const src = trigger.dataset.src;
          const alt = trigger.dataset.alt ?? "";
          if (!src) {
            return;
          }
          lightboxImage.src = src;
          lightboxImage.alt = alt;
          lightbox.showModal();
        });
      });

      closeButton?.addEventListener("click", () => lightbox.close());

      lightbox.addEventListener("click", (event) => {
        const rect = lightbox.getBoundingClientRect();
        const clickedOutside =
          event.clientX < rect.left ||
          event.clientX > rect.right ||
          event.clientY < rect.top ||
          event.clientY > rect.bottom;
        if (clickedOutside) {
          lightbox.close();
        }
      });
    });
  </script>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(productLd)} />
</Layout>
