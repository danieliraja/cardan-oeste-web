---
const year = new Date().getFullYear();
---

<footer class="font-[sans-serif] bg-gray-950 p-10">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div class="w-full">
        <a href="/">
          <img src="/images/logo-white.png" alt="logo" class="h-32 w-auto" />
        </a>
        <ul class="mt-4 flex justify-start gap-4">
          <li>
            <a
              href="https://www.facebook.com/share/19uMfeuuPh/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white"
              aria-label="Facebook Cardan Oeste"
            >
              <i class="bi bi-facebook text-gray-300 hover:text-white text-2xl"
              ></i>
            </a>
          </li>
        </ul>
      </div>

      <div class="w-full">
        <h4
          class="text-white font-semibold text-lg relative max-sm:cursor-pointer"
        >
          Contato
        </h4>
        <ul class="mt-4 space-y-3 text-gray-300 text-sm">
          <li><strong class="text-white">Jhonny:</strong> (21) 96421-0745</li>
          <li><strong class="text-white">Vaval:</strong> (21) 97022-8344</li>
          <li><strong class="text-white">Pagamento:</strong> até 3x sem juros</li>
        </ul>
      </div>

      <div class="w-full">
        <h4
          class="text-white font-semibold text-lg relative max-sm:cursor-pointer"
        >
          Endereço
        </h4>
        <ul class="mt-4 space-y-3 text-gray-300 text-sm">
          <li>
            <a
              href="https://www.google.com/maps/search/?api=1&query=Estrada+do+Col%C3%A9gio,+524,+Col%C3%A9gio,+Rio+de+Janeiro,+RJ"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white underline underline-offset-4"
              aria-label="Abrir endereço da Cardan Oeste no Google Maps"
            >
              Estrada do Colégio, 524 - Colégio, Rio de Janeiro / RJ
            </a>
          </li>
          <li>Atendimento para linha pesada e industrial</li>
        </ul>
      </div>
    </div>
    <hr class="mt-8 border-gray-300" />
    <div class="mt-8">
      <p class="text-gray-300 text-sm">
        Cardan Oeste © {year} | Todos os direitos reservados
      </p>
    </div>
  </div>
</footer>
