---
import astroConfig from "../../astro.config.mjs";

const navigation = [
  { href: "#inicio", label: "Início" },
  { href: "#sobre", label: "Sobre" },
  { href: "#servicos", label: "Serviços" },
  { href: "#cardans", label: "Linha de cardans" },
  { href: "#contato", label: "Contato" },
];
---

<header class="sticky top-0 z-50">
  <div class="border-b border-white/10 bg-gradient-to-r from-slate-900 via-slate-800 to-blue-900 text-white">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-6 py-2 text-xs sm:flex-row sm:items-center sm:justify-between">
      <p class="flex items-center gap-2">
        <i class="bi bi-geo-alt-fill text-blue-200"></i>
        Atendimento em todo o RJ com retirada e entrega expressa
      </p>
      <p class="flex items-center gap-2 text-blue-100">
        <i class="bi bi-clock-history"></i>
        Plantão técnico 24/7 para frotas e contratos industriais
      </p>
    </div>
  </div>
  <nav class="border-b border-slate-200 bg-white/95 shadow-sm backdrop-blur" aria-label="Global">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 lg:px-8">
      <a href={astroConfig.site} class="flex items-center gap-3">
        <span class="sr-only">Cardan Oeste</span>
        <img
          class="h-14 w-auto"
          src={astroConfig.site + "/images/logo-ilustrativo-removebg-preview.png"}
          alt="Logo Cardan Oeste"
        />
        <div class="hidden text-left font-semibold text-slate-800 md:block">
          <p class="text-[0.65rem] uppercase tracking-[0.4em] text-blue-600">Cardan Oeste</p>
          <p class="text-sm">Engenharia em transmissões pesadas</p>
        </div>
      </a>

      <div class="hidden items-center gap-8 lg:flex">
        {navigation.map((item) => (
          <a
            href={astroConfig.site + item.href}
            class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-700 transition hover:text-blue-700"
          >
            {item.label}
          </a>
        ))}
        <a
          href="https://api.whatsapp.com/send?phone=5521974210745"
          class="inline-flex items-center gap-2 rounded-full bg-blue-700 px-6 py-2 text-sm font-semibold text-white shadow-lg shadow-blue-700/40 transition hover:bg-blue-800"
        >
          <i class="bi bi-whatsapp text-lg"></i>
          <span>Chamar consultor</span>
        </a>
      </div>

      <div class="flex items-center gap-3 lg:hidden">
        <a
          href="https://api.whatsapp.com/send?phone=5521974210745"
          class="inline-flex items-center gap-2 rounded-full bg-blue-700 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-blue-700/40 transition hover:bg-blue-800"
        >
          <i class="bi bi-whatsapp text-lg"></i>
          <span>Contato</span>
        </a>
        <button
          type="button"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-300 text-slate-800 transition hover:border-blue-600 hover:text-blue-700"
          id="mobile-menu-button"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="sr-only">Abrir menu</span>
          <i class="bi bi-list text-2xl"></i>
        </button>
      </div>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="fixed inset-0 top-[5.5rem] z-40 hidden -translate-y-6 transform bg-slate-950/95 px-6 pb-16 pt-8 text-white opacity-0 transition-all duration-300"
  >
    <div class="mx-auto flex max-w-sm flex-col gap-4">
      {navigation.map((item) => (
        <a
          href={astroConfig.site + item.href}
          class="rounded-2xl border border-white/10 px-5 py-3 text-base font-semibold tracking-[0.2em] uppercase transition hover:bg-white/10"
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://api.whatsapp.com/send?phone=5521974210745"
        class="mt-2 inline-flex items-center justify-center gap-2 rounded-full bg-blue-600 px-5 py-3 text-base font-semibold text-white shadow-lg shadow-blue-600/40 transition hover:bg-blue-700"
      >
        <i class="bi bi-whatsapp text-lg"></i>
        <span>Chamar consultor</span>
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuLinks = mobileMenu?.querySelectorAll("a");

    const toggleMenu = (forceClose = false) => {
      const isOpen = mobileMenu?.classList.contains("opacity-100");
      const shouldOpen = forceClose ? false : !isOpen;

      if (shouldOpen) {
        mobileMenu?.classList.remove("hidden", "opacity-0", "-translate-y-6");
        mobileMenu?.classList.add("opacity-100");
        mobileMenuButton?.setAttribute("aria-expanded", "true");
      } else {
        mobileMenu?.classList.remove("opacity-100");
        mobileMenu?.classList.add("opacity-0", "-translate-y-6");
        setTimeout(() => mobileMenu?.classList.add("hidden"), 200);
        mobileMenuButton?.setAttribute("aria-expanded", "false");
      }
    };

    mobileMenuButton?.addEventListener("click", () => toggleMenu());

    menuLinks?.forEach((link) =>
      link.addEventListener("click", () => toggleMenu(true))
    );

    document.addEventListener("keyup", (event) => {
      if (event.key === "Escape") {
        toggleMenu(true);
      }
    });
  });
</script>
